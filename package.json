{
  "name": "dear-stranger-archive",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://peaceandmusic.net",
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "overrides": {
    "postcss": "^8.5.14"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "autoprefixer": "^10.4.20",
    "classnames": "^2.5.1",
    "framer-motion": "^12.4.1",
    "howler": "^2.2.4",
    "i18next": "^25.8.1",
    "next": "^16.2.4",
    "next-i18next": "^15.3.1",
    "postcss": "^8.5.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.0.0",
    "react-i18next": "^16.5.4",
    "tailwindcss": "^3.4.15",
    "typescript": "5.7.3",
    "web-vitals": "^2.1.4",
    "zod": "^4.4.3"
  },
  "scripts": {
    "start": "next start",
    "postinstall": "patch-package",
    "build": "next build",
    "postbuild": "next-sitemap",
    "test": "jest",
    "generate:artist-cards": "node scripts/generate-artist-cards.js",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "lint": "eslint src pages",
    "lint:fix": "eslint src pages --fix",
    "analyze": "ANALYZE=true next build",
    "analyze:source-map": "source-map-explorer '.next/static/chunks/*.js'",
    "dev": "next dev",
    "i18n:extract": "i18next-parser",
    "i18n:check": "i18next-parser --fail-on-warnings",
    "build:timetable": "ts-node --compiler-options '{\"module\":\"commonjs\"}' scripts/convert-timetable.ts",
    "fonts:subset": "python3 scripts/subset-fonts.py"
  },
  "browserslist": {
    "production": [
      "chrome >= 93",
      "edge >= 93",
      "firefox >= 92",
      "safari >= 15.4",
      "ios_saf >= 15.4",
      "samsung >= 16",
      "and_chr >= 93",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@next/bundle-analyzer": "^16.2.4",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^14.3.1",
    "@types/howler": "^2.2.12",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-jest": "^29.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^15.0.0",
    "i18next-parser": "^9.0.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "next-sitemap": "^4.2.3",
    "open-graph-scraper": "^6.8.2",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.2",
    "puppeteer": "^24.40.0",
    "sharp": "^0.33.5",
    "source-map-explorer": "^2.5.3",
    "ts-node": "^10.9.2",
    "xlsx": "^0.18.5"
  }
}
