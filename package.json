{
  "name": "dear-stranger-archive",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://peaceandmusic.net",
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "autoprefixer": "^10.4.20",
    "classnames": "^2.5.1",
    "framer-motion": "^12.4.1",
    "howler": "^2.2.4",
    "i18next": "^25.8.1",
    "next": "^16.2.4",
    "next-i18next": "^15.3.1",
    "postcss": "^8.5.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.0.0",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^3.4.15",
    "typescript": "5.7.3",
    "web-vitals": "^2.1.4",
    "zod": "^4.4.3"
  },
  "scripts": {
    "start": "next start",
    "postinstall": "patch-package",
    "build": "next build",
    "postbuild": "next-sitemap",
    "test": "jest",
    "generate:artist-cards": "node scripts/generate-artist-cards.js",
    "typecheck": "tsc --noEmit --pretty false",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"pages/**/*.{ts,tsx,js,jsx}\" \"scripts/**/*.{ts,tsx,js,mjs,json}\" \"*.{md,json,js}\" \".github/workflows/*.{yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"pages/**/*.{ts,tsx,js,jsx}\" \"scripts/**/*.{ts,tsx,js,mjs,json}\" \"*.{md,json,js}\" \".github/workflows/*.{yml,yaml}\"",
    "lint": "eslint src pages proxy.ts scripts/check-timetable-generated.mjs scripts/convert-timetable.ts",
    "lint:fix": "eslint src pages proxy.ts scripts/check-timetable-generated.mjs scripts/convert-timetable.ts --fix",
    "analyze": "ANALYZE=true next build",
    "analyze:source-map": "source-map-explorer '.next/static/chunks/*.js'",
    "dev": "next dev",
    "i18n:extract": "node scripts/extract-i18n.mjs",
    "i18n:check": "node scripts/check-missing-translations.mjs && node scripts/check-deep-translations.mjs",
    "static:check": "node scripts/check-static-assets.mjs",
    "seed:archive-cms": "ts-node --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' scripts/seed-admin-archive.ts",
    "seed:archive-cms:sql": "ts-node --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' scripts/generate-admin-archive-seed-sql.ts",
    "build:timetable": "ts-node --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' scripts/convert-timetable.ts",
    "timetable:check": "node scripts/check-timetable-generated.mjs",
    "fonts:subset": "python3 scripts/subset-fonts.py"
  },
  "browserslist": {
    "production": [
      "chrome >= 93",
      "edge >= 93",
      "firefox >= 92",
      "safari >= 15.4",
      "ios_saf >= 15.4",
      "samsung >= 16",
      "and_chr >= 93",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.6",
      "postcss": "8.5.15"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@next/bundle-analyzer": "^16.2.4",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^14.3.1",
    "@types/howler": "^2.2.12",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-jest": "^29.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^15.0.0",
    "i18next-cli": "^1.63.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "next-sitemap": "^4.2.3",
    "open-graph-scraper": "^6.8.2",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.2",
    "puppeteer": "^24.40.0",
    "read-excel-file": "^9.1.1",
    "sharp": "^0.33.5",
    "source-map-explorer": "^2.5.3",
    "ts-node": "^10.9.2"
  }
}
